<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dm_arm">

    <xacro:arg name="use_fake_hardware" default="false"/>
    <xacro:arg name="serial_port" default="/dev/ttyACM0"/>
    <xacro:arg name="baudrate" default="921600"/>
    <xacro:arg name="enable_write" default="true"/>
    <xacro:arg name="refresh_state_in_read" default="false"/>
    <xacro:arg name="startup_read_cycles" default="5"/>
    <xacro:arg name="legacy_feedforward_enabled" default="true"/>
    <xacro:arg name="legacy_pd_fallback" default="true"/>
    <xacro:arg name="command_mode" default="impedance"/>

    <xacro:arg name="enable_dynamics" default="true"/>
    <xacro:arg name="enable_gravity_feedforward" default="true"/>
    <xacro:arg name="enable_nonlinear_feedforward" default="false"/>
    <xacro:arg name="urdf_path" default="$(find dm_arm_description)/urdf/DM-Arm-Description.urdf"/>

    <xacro:include filename="$(find dm_arm_description)/urdf/DM-Arm-Description.urdf" />

    <ros2_control name="DmArmSystem" type="system">
        <hardware>
            <xacro:if value="$(arg use_fake_hardware)">
                <plugin>mock_components/GenericSystem</plugin>
            </xacro:if>

            <xacro:unless value="$(arg use_fake_hardware)">
                <plugin>dm_ros_control/DmHardwareInterface</plugin>
                <param name="serial_port">$(arg serial_port)</param>
                <param name="baudrate">$(arg baudrate)</param>
                <param name="control_frequency">200.0</param>
                <param name="enable_write">$(arg enable_write)</param>
                <param name="refresh_state_in_read">$(arg refresh_state_in_read)</param>
                <param name="startup_read_cycles">$(arg startup_read_cycles)</param>
                <param name="legacy_feedforward_enabled">$(arg legacy_feedforward_enabled)</param>
                <param name="legacy_pd_fallback">$(arg legacy_pd_fallback)</param>
                <param name="command_mode">$(arg command_mode)</param>

                <param name="enable_dynamics">$(arg enable_dynamics)</param>
                <param name="enable_gravity_feedforward">$(arg enable_gravity_feedforward)</param>
                <param name="enable_nonlinear_feedforward">$(arg enable_nonlinear_feedforward)</param>
                <param name="urdf_path">$(arg urdf_path)</param>
            </xacro:unless>
        </hardware>

        <joint name="joint1">
            <param name="motor_id">1</param>
            <param name="motor_type">2</param>
            <param name="control_mode">MIT</param>
            <param name="joint_to_motor_scale">1.0</param>
            <command_interface name="position"/>
            <command_interface name="velocity"/>
            <command_interface name="effort"/>
            <command_interface name="kp"/>
            <command_interface name="kd"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="motor_effort"/>
            <state_interface name="gravity_effort"/>
            <state_interface name="nonlinear_effort"/>
            <state_interface name="feedforward_effort"/>
            <state_interface name="external_effort"/>
        </joint>

        <joint name="joint2">
            <param name="motor_id">2</param>
            <param name="motor_type">2</param>
            <param name="control_mode">MIT</param>
            <param name="joint_to_motor_scale">1.0</param>
            <command_interface name="position"/>
            <command_interface name="velocity"/>
            <command_interface name="effort"/>
            <command_interface name="kp"/>
            <command_interface name="kd"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="motor_effort"/>
            <state_interface name="gravity_effort"/>
            <state_interface name="nonlinear_effort"/>
            <state_interface name="feedforward_effort"/>
            <state_interface name="external_effort"/>
        </joint>

        <joint name="joint3">
            <param name="motor_id">3</param>
            <param name="motor_type">2</param>
            <param name="control_mode">MIT</param>
            <param name="joint_to_motor_scale">1.0</param>
            <command_interface name="position"/>
            <command_interface name="velocity"/>
            <command_interface name="effort"/>
            <command_interface name="kp"/>
            <command_interface name="kd"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="motor_effort"/>
            <state_interface name="gravity_effort"/>
            <state_interface name="nonlinear_effort"/>
            <state_interface name="feedforward_effort"/>
            <state_interface name="external_effort"/>
        </joint>

        <joint name="joint4">
            <param name="motor_id">4</param>
            <param name="motor_type">1</param>
            <param name="control_mode">MIT</param>
            <param name="joint_to_motor_scale">1.0</param>
            <command_interface name="position"/>
            <command_interface name="velocity"/>
            <command_interface name="effort"/>
            <command_interface name="kp"/>
            <command_interface name="kd"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="motor_effort"/>
            <state_interface name="gravity_effort"/>
            <state_interface name="nonlinear_effort"/>
            <state_interface name="feedforward_effort"/>
            <state_interface name="external_effort"/>
        </joint>

        <joint name="joint5">
            <param name="motor_id">5</param>
            <param name="motor_type">1</param>
            <param name="control_mode">MIT</param>
            <param name="joint_to_motor_scale">1.0</param>
            <command_interface name="position"/>
            <command_interface name="velocity"/>
            <command_interface name="effort"/>
            <command_interface name="kp"/>
            <command_interface name="kd"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="motor_effort"/>
            <state_interface name="gravity_effort"/>
            <state_interface name="nonlinear_effort"/>
            <state_interface name="feedforward_effort"/>
            <state_interface name="external_effort"/>
        </joint>

        <joint name="joint6">
            <param name="motor_id">6</param>
            <param name="motor_type">1</param>
            <param name="control_mode">MIT</param>
            <param name="joint_to_motor_scale">1.0</param>
            <command_interface name="position"/>
            <command_interface name="velocity"/>
            <command_interface name="effort"/>
            <command_interface name="kp"/>
            <command_interface name="kd"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="motor_effort"/>
            <state_interface name="gravity_effort"/>
            <state_interface name="nonlinear_effort"/>
            <state_interface name="feedforward_effort"/>
            <state_interface name="external_effort"/>
        </joint>

        <joint name="gripper_left">
            <param name="motor_id">7</param>
            <param name="motor_type">1</param>
            <param name="control_mode">MIT</param>
            <param name="joint_to_motor_scale">118.55066617319976</param>
            <command_interface name="position"/>
            <command_interface name="velocity"/>
            <command_interface name="effort"/>
            <command_interface name="kp"/>
            <command_interface name="kd"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="motor_effort"/>
            <state_interface name="gravity_effort"/>
            <state_interface name="nonlinear_effort"/>
            <state_interface name="feedforward_effort"/>
            <state_interface name="external_effort"/>
        </joint>
    </ros2_control>
</robot>
