<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
    <!-- ========================= 基本信息(必填) ========================= -->

    <!-- TODO: 修改包名(必须与 CMakeLists.txt 中的 project() 一致) -->
    <name>dm_controller</name>

    <!-- TODO: 修改其他信息：版本号、包描述、维护者信息、许可证(MIT, BSD, Apache-2.0, GPL-3.0...) -->
