    <description>ROS2 package template</description>
    <maintainer email="your.email@example.com">Your Name</maintainer>
    <license>MIT</license>

    <!-- ========================= 可选信息 ========================= -->

    <!-- TODO: 可选，添加作者信息、项目网址 -->
